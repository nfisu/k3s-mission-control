name: Build and Deploy to K3s

on:
  push:
    branches:
      - main

env:
  IMAGE_NAME: ${{ secrets.DOCKERHUB_USERNAME }}/k3s-mission-control

jobs:
  build-and-push:
    name: Build Docker Image
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKERHUB_USERNAME }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}

      - run: |
          docker build -t $IMAGE_NAME:latest .
          docker tag $IMAGE_NAME:latest $IMAGE_NAME:${{ github.sha }}

      - run: |
          docker push $IMAGE_NAME:latest
          docker push $IMAGE_NAME:${{ github.sha }}
  deploy:
    name: Deploy to K3s
    runs-on: ubuntu-latest
    needs: build-and-push
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up kubectl
        uses: azure/setup-kubectl@v3

      - name: Write kubeconfig
        run: |
          mkdir -p $HOME/.kube
          cat <<'EOF' > $HOME/.kube/config
          ${{ secrets.KUBECONFIG_DATA }}
          EOF
          chmod 600 $HOME/.kube/config
          echo "KUBECONFIG=$HOME/.kube/config" >> $GITHUB_ENV

      - name: Verify kubeconfig file exists
        run: |
          ls -l $HOME/.kube/config
          test -s $HOME/.kube/config

    - name: Verify cluster access
      run: |
        kubectl config current-context
        kubectl get nodes

    - name: Update image tag in deployment manifest
      run: |
        sed -i "s|nfisu/k3s-mission-control:latest|$IMAGE_NAME:${{ github.sha }}|g" k8s/deployment.yaml

    - name: Apply manifests to K3s
      run: |
        kubectl apply -f k8s/configmap.yaml --validate=false
        kubectl apply -f k8s/deployment.yaml --validate=false
        kubectl apply -f k8s/service.yaml --validate=false

    - name: Wait for rollout
      run: kubectl rollout status deployment/mission-control --timeout=120s

    - name: Show running pods
      run: |
        kubectl get pods -l app=mission-control
        kubectl get service mission-control-service

